# Home Assistant
HA_BASE_URL=http://homeassistant.local:8123
HA_TOKEN=

# Optional price/weather connectors
PRICE_API_URL=
PRICE_API_KEY=
WEATHER_API_URL=
WEATHER_API_KEY=

# Notifications
SLACK_WEBHOOK_URL=
WHATSAPP_WEBHOOK_URL=

# MQTT (optional but recommended)
MQTT_HOST=
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
# comma-separated topic filters, e.g. sensors/temperature/#,prices/crypto/#
MQTT_TOPICS=

# InfluxDB (episodic memory + time-series features)
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_TOKEN=
INFLUXDB_ORG=auroran
INFLUXDB_BUCKET=health
INFLUXDB_AI_MEMORY_BUCKET=ha_ai_memory

# Hard policy constraints
BEDROOM_HP_ENTITY=climate.ac_12488762
BEDROOM_HP_OFF_START_HOUR=19
BEDROOM_HP_OFF_END_HOUR=9
LOCAL_TIMEZONE=Europe/Helsinki

# Behavior
AUTO_APPLY=false
POLL_INTERVAL_SECONDS=300
